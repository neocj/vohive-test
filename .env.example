TZ=Asia/Shanghai

# Required before first start. Set a strong password in your local .env file.
# Do not commit real passwords.
# VOHIVE_ADMIN_PASSWORD=

# Required for full iStoreOS modem access. Set only the device nodes that VoHive should use.
# Do not map /dev and do not enable privileged mode.
# VOHIVE_SERIAL_DEVICE=/dev/ttyUSB2
# VOHIVE_CONTROL_DEVICE=/dev/cdc-wdm0
